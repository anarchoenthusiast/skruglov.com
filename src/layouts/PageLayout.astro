---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@consts";

type Props = {
  title: string;
  description: string;
  pageType?: "default" | "blog" | "project";
  breadcrumbs?: {
    label: string;
    url?: string;
  }[];
  hideHeader?: boolean;
  canonicalURL?: string;
  robots?: string;
  structuredData?: object | object[];
  ogType?: string;
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
};

const { 
  title, 
  description, 
  pageType = "default", 
  breadcrumbs, 
  hideHeader = false,
  canonicalURL,
  robots,
  structuredData,
  ogType,
  ogImage,
  publishedTime,
  modifiedTime,
  authorName
} = Astro.props;

// Определяем, является ли текущая страница главной
const isHomePage = Astro.url.pathname === "/";
const shouldShowHeader = !isHomePage && !hideHeader;

const pageTitle = isHomePage
  ? `${SITE.NAME} - Product Designer and Engineer`
  : `${title} | ${SITE.NAME}`;

const breadcrumbStructuredData = breadcrumbs && breadcrumbs.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: item.label,
        item: new URL(item.url ?? Astro.url.pathname, Astro.site).href,
      })),
    }
  : undefined;

const structuredDataItems = [
  ...(Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : []),
  ...(breadcrumbStructuredData ? [breadcrumbStructuredData] : []),
];
const finalStructuredData = structuredDataItems.length === 0
  ? undefined
  : structuredDataItems.length === 1
    ? structuredDataItems[0]
    : structuredDataItems;
---

<!doctype html>
<html lang="en">
  <head>
    <Head 
      title={pageTitle} 
      description={description}
      canonicalURL={canonicalURL}
      robots={robots}
      structuredData={finalStructuredData}
      ogType={ogType}
      ogImage={ogImage}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      authorName={authorName}
    />
    <ClientRouter />
  </head>
  <body>
    {shouldShowHeader && <Header pageType={pageType} breadcrumbs={breadcrumbs} />}
    <main>
      <slot />
    </main>
    <Footer pageType={pageType} />
    <Navbar />
  </body>
</html>
